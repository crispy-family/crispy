@{
    ViewData["Title"] = "Відновлення паролю";
}

<div class="text-center mt-5">
    <h2>Перевірте вашу електронну пошту</h2>
    <p>
        Ми відправили посилання для відновлення паролю на вашу пошту.
        Будь ласка, перевірте папку "Вхідні" (або "Спам").
    </p>
    <a asp-action="Login" asp-controller="Account" class="btn btn-outline-primary mt-3">
        Повернутися до входу
    </a>
</div>